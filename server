-- ServerScriptService 内创建脚本粘贴
local Players = game:GetService("Players")
local DataStoreService = game:GetService("DataStoreService")

-- 存储每位玩家的游玩时长
local PlayerPlayTime = {}
-- 定时刷新间隔(秒)
local RefreshInterval = 1

-- 玩家加入时初始化计时
local function OnPlayerAdded(player)
    local joinTime = os.clock() -- 记录进入时间

    -- 持续计时
    local loopConn
    loopConn = game.Players.PlayerRemoving:Connect(function(leavingPlayer)
        if leavingPlayer == player then
            local playSecond = math.floor(os.clock() - joinTime)
            PlayerPlayTime[player.UserId] = {
                Name = player.Name,
                Time = playSecond
            }
            loopConn:Disconnect()
        end
    end)
end

-- 定时输出：游玩最长的玩家排行榜
local function ShowLongestPlayPlayer()
    print("\n========== 游玩时长最长玩家排行榜 ==========")
    
    -- 转数组排序
    local list = {}
    for uid,data in pairs(PlayerPlayTime) do
        table.insert(list,data)
    end

    -- 按时长从大到小排序
    table.sort(list,function(a,b)
        return a.Time > b.Time
    end)

    -- 打印前10名
    for i = 1,math.min(10,#list) do
        local d = list[i]
        local min = math.floor(d.Time / 60)
        local sec = d.Time % 60
        print(string.format("第%d名 | 玩家：%s | 时长：%d分%d秒",i,d.Name,min,sec))
    end
    print("==========================================\n")
end

-- 绑定玩家加入事件
Players.PlayerAdded:Connect(OnPlayerAdded)

-- 循环定时检测
while task.wait(RefreshInterval) do
    ShowLongestPlayPlayer()
end

