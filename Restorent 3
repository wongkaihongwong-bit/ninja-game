-- 窗口拖动逻辑
local Draging, StartMouse, StartFrame
TopBar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        Draging = true
        StartMouse = input.Position
        StartFrame = MainFrame.Position
    end
end)
TopBar.InputChanged:Connect(function(input)
    if Draging and input.UserInputType == Enum.UserInputType.MouseMovement then
        local Delta = input.Position - StartMouse
        MainFrame.Position = UDim2.new(
            StartFrame.X.Scale, StartFrame.X.Offset + Delta.X,
            StartFrame.Y.Scale, StartFrame.Y.Offset + Delta.Y
        )
    end
end)
TopBar.InputEnded:Connect(function()
    Draging = false
end)

-- 收缩/展开逻辑
