MinBtn.MouseButton1Click:Connect(function()
    IsMin = not IsMin
    if IsMin then
        Content.Visible = false
        MainFrame.Size = UDim2.new(0, 300, 0, 35)
        MinBtn.Text = "□"
    else
        Content.Visible = true
        MainFrame.Size = UDim2.new(0, 300, 0, 400)
        MinBtn.Text = "—"
    end
end)

