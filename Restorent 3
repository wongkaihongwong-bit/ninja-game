-- 自动收集钱
local AutoCollectRunning = false
CollectBtn.MouseButton1Click:Connect(function()
    AutoCollectRunning = not AutoCollectRunning
    if AutoCollectRunning then
        CollectBtn.BackgroundColor3 = Color3.fromRGB(20, 100, 20)
        CollectBtn.Text = "🟢 开启自动收集"
        Notify("自动收集已开启！人物会自动跑去捡钱")
        
        task.spawn(function()
            while AutoCollectRunning and task.wait(0.3) do
                pcall(function()
                    for _, part in ipairs(Workspace:GetDescendants()) do
                        if part:IsA("Part") and (
                            part.Name:lower():find("cash") or 
                            part.Name:lower():find("money") or 
                            part.Name:lower():find("coin") or 
                            part.Name:lower():find("tip")
                        ) then
                            if Humanoid.Health > 0 and not Humanoid.Sit then
                                Character:MoveTo(part.Position + Vector3.new(0, 2, 0))
                            end
                        end
                    end
                end)
            end
        end)
    else
        CollectBtn.BackgroundColor3 = Color3.fromRGB(45, 45, 55)
        CollectBtn.Text = "🔴 关闭自动收集"
        Notify("自动收集已关闭")
    end
end)

